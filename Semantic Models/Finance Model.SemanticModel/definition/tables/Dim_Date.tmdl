table Dim_Date
	lineageTag: 9eca578a-4f5f-4ed8-937f-4fa4ebd05d87
	sourceLineageTag: [dbo].[mtbl_EDW_Dim_Date]
	dataCategory: Time

	measure 'Selected Dates (Orders Only)' = ```
			
			VAR DatesWithOrders =
			    CALCULATETABLE(
			        VALUES('Dim_Date'[Date]),
			        KEEPFILTERS(
			            FILTER(ALLSELECTED('Dim_Date'[Date]), [Total Orders] > 0)
			        )
			    )
			RETURN
			IF(
			    COUNTROWS(DatesWithOrders) = 0,
			    "No dates selected",
			    CONCATENATEX(
			        DatesWithOrders,
			        FORMAT('Dim_Date'[Date], "MMMM DD, YYYY"),
			        ", "
			    )
			)
			
			```
		lineageTag: 1521795c-530f-4090-810c-399ad6b8e27a

		changedProperty = Name

	measure 'Selected Date Range (Orders Only)' = ```
			
			VAR DatesWithOrders =
			    CALCULATETABLE(
			        VALUES('Dim_Date'[Date]),
			        KEEPFILTERS(
			            FILTER(ALLSELECTED('Dim_Date'[Date]), [Total Orders] > 0)
			        )
			    )
			VAR MinDate = MINX(DatesWithOrders, 'Dim_Date'[Date])
			VAR MaxDate = MAXX(DatesWithOrders, 'Dim_Date'[Date])
			VAR CountDates = COUNTROWS(DatesWithOrders)
			RETURN
			SWITCH(
			    TRUE(),
			    CountDates = 0, "No dates selected",
			    MinDate = MaxDate, FORMAT(MinDate, "MMMM DD, YYYY"),
			    FORMAT(MinDate, "MMMM DD, YYYY") & " - " & FORMAT(MaxDate, "MMMM DD, YYYY")
			)
			
			```
		lineageTag: d16b925e-1a50-4204-af44-52950966915a

		changedProperty = Name

	measure 'Requested Ship Date' = ```
			
			VAR dk = VALUES ( 'Fact_Sales'[SalesLine_RequestedShipDateKey] )
			RETURN
			CALCULATE (
			    SELECTEDVALUE ( 'Dim_Date'[Date] ),
			    -- neutralize any existing Dim_Date filter coming from the active relationship
			    REMOVEFILTERS ( 'Dim_Date' ),
			    -- apply the requested-ship keys as a filter on the date dimension
			    TREATAS ( dk, 'Dim_Date'[DateKey] )
			)
			
			```
		formatString: General Date
		lineageTag: 084aed39-00c8-4eb4-84f2-59ae863295d7

		changedProperty = Name

