	measure 'Week Start (Mon)' = ```
			
			VAR d = MAX ( 'Dim_Date'[Date] )         -- the date in the current filter context
			RETURN
			d - WEEKDAY ( d, 2 ) + 1                 -- 2 => Monday=1 ... Sunday=7
			
			```
		formatString: General Date
		lineageTag: 67e24fe5-df34-4462-9c79-02fea7f9ad51

		changedProperty = Name

	measure 'Requested Ship Date (Max)' = ```
			
			VAR dk =
			    VALUES ( 'Fact_Sales'[SalesLine_RequestedShipDateKey] )
			RETURN
			CALCULATE (
			    MAX ( 'Dim_Date'[Date] ),          -- get the furthest date
			    REMOVEFILTERS ( 'Dim_Date' ),      -- ignore existing date filters
			    TREATAS ( dk, 'Dim_Date'[DateKey] )
			)
			
			```
		formatString: General Date
		lineageTag: 0f43fdb9-c73d-418b-bdb4-e49c52fd22e5

		changedProperty = Name

	measure BaseMonthStart =
			
			VAR Offset =
			    SELECTEDVALUE ( 'Month View'[Offset], 0 )   -- default: This Month
			VAR Anchor =
			    EDATE ( TODAY(), Offset )                  -- same day in shifted month
			RETURN
			    DATE ( YEAR ( Anchor ), MONTH ( Anchor ), 1 )
		formatString: General Date
		lineageTag: d9427f5f-de4f-4641-bd5a-c843655b57df

		changedProperty = Name

	measure BaseMonthEnd =
			
			VAR Offset =
			    SELECTEDVALUE ( 'Month View'[Offset], 0 )
			VAR Anchor =
			    EDATE ( TODAY(), Offset )
			RETURN
			    EOMONTH ( Anchor, 0 )
		formatString: General Date
		lineageTag: 0ccb3d88-c607-438c-bf0c-307980ed0f76

		changedProperty = Name

	measure NextMonthStart =
			
			VAR Offset =
			    SELECTEDVALUE ( 'Month View'[Offset], 0 )
			VAR Anchor =
			    EDATE ( TODAY(), Offset + 1 )              -- one month after base
			RETURN
			    DATE ( YEAR ( Anchor ), MONTH ( Anchor ), 1 )
		formatString: General Date
		lineageTag: 11366254-0e84-4bde-8b9b-9c6c9c147c16

		changedProperty = Name

	measure NextMonthEnd =
			
			VAR Offset =
			    SELECTEDVALUE ( 'Month View'[Offset], 0 )
			VAR Anchor =
			    EDATE ( TODAY(), Offset + 1 )
			RETURN
			    EOMONTH ( Anchor, 0 )
		formatString: General Date
		lineageTag: f916be4e-b6e9-4650-ba1e-c2a00baed9dd

		changedProperty = Name

	measure 'Month View Title' = ```
			
			VAR Offset =
			    SELECTEDVALUE ( 'Month View'[Offset], 0 )
			VAR Anchor =
			    EDATE ( TODAY (), Offset )
			VAR LabelText =
			    SWITCH (
			        Offset,
			        0,  "This Month",
			       -1,  "Previous Month",
			           "Selected Month"
			    )
			RETURN
			    FORMAT ( Anchor, "MMMM 'yy" )
			
			```
		lineageTag: 17bb1a03-cf47-435f-88ca-b48335744153

		changedProperty = Name

