	measure 'Total Invoices' = COUNTROWS(Fact_Customer_Invoices)
		formatString: 0
		lineageTag: 029f0373-62b7-49f3-8de4-59816e864520

		changedProperty = Name

	measure InvoicePricePerLB = Divide([Invoice Line Amount] , [Invoice Quantity (LBs)])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: c6d4fa59-144a-4d87-915c-275a2b7e9c4a

		changedProperty = Name

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Invoice Line Sum (Customer)' = ```
			
			
			CALCULATE(
			    [Invoice Line Sum],
			
			    -- Turn OFF the active relationship: Fact[InvoiceAccountKey] -> Dim_Account[CustomerKey]
			    CROSSFILTER(
			        'Fact_Customer_Invoices'[InvoiceCustomerKey],
			        'Dim_Account'[CustomerKey],
			        NONE
			    ),
			
			    -- Turn ON the inactive relationship: Fact[CustomerKey] -> Dim_Account[CustomerKey]
			    USERELATIONSHIP(
			        'Fact_Customer_Invoices'[CustomerKey],
			        'Dim_Account'[CustomerKey]
			    )
			)
			
			```
		lineageTag: 168f5af6-f732-44f8-8967-7c813a300ba8

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure InvoiceAmountCard =
			
			COALESCE (
			    [Invoice Line Sum],
			    0
			)
		lineageTag: c323924b-6887-466c-9aeb-ead6425ee6c2

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Invoice Charges' =
			
			[Invoice Line Sum] - [Invoice Line Amount]
		lineageTag: 319a2324-8c17-4756-9966-bc0364e4a552

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

