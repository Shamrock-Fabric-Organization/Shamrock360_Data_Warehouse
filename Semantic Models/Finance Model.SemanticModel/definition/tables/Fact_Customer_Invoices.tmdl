	measure 'Invoice Line Sum' = [Invoice Line Amount] + [Invoice Freight] + [Invoice Fuel Charge] + [Invoice Pallet Break] + [Invoice Tariff Surcharge]
		lineageTag: 366dfb3a-c4e8-40b0-b0c3-6931dfbdfb7a

