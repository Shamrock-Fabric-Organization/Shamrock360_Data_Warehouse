	measure 'YTD Revenue Deficit' = ```
			
			SUMX(
			    // 1) build the list of salesman–account pairs in the current filter context
			    FILTER(
			        SUMMARIZE(
			            'vw360_Fact_Sales',
			            'vw360_Salesman_Hierarchy'[RegionalSalesman],
			            'vw360_Dim_Account'[GlobalName],
			            'vw360_Fact_Sales'[Product]
			        ),
			        // 2) only keep those pairs whose variance is below zero
			        CALCULATE( [YTD_Volume_Variance] ) < 0
			    ),
			    // 3) for each remaining pair, compute (Total – Budget) and add them up
			    CALCULATE( [YTD_Revenue_Total] ) 
			    - CALCULATE( [YTD_Revenue_Budget] )
			)
			
			```
		lineageTag: f2fe29f4-d37f-4360-9c68-e44554f0df05

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YTD Volume Deficit' = ```
			
			SUMX(
			    // 1) build the list of salesman–account pairs in the current filter context
			    FILTER(
			        SUMMARIZE(
			            'vw360_Fact_Sales',
			            'vw360_Salesman_Hierarchy'[RegionalSalesman],
			            'vw360_Dim_Account'[GlobalName],
			            'vw360_Fact_Sales'[Product]
			        ),
			        // 2) only keep those pairs whose variance is below zero
			        CALCULATE( [YTD_Volume_Variance] ) < 0
			    ),
			    // 3) for each remaining pair, compute (Total – Budget) and add them up
			    CALCULATE( [YTD_Volume_Total] ) 
			    - CALCULATE( [YTD_Volume_Budget] )
			)
			
			```
		lineageTag: 2e63a443-b006-45a1-bb19-9e2bef03e9a8

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

