	measure 'Revenue running total in FISCAL Period' =
			
			CALCULATE(
				SUM('vw360_Fact_Sales'[Revenue]),
				FILTER(
					ALLSELECTED('vw360_Dim_InvoiceDate'[FISCAL PERIOD]),
					ISONORAFTER('vw360_Dim_InvoiceDate'[FISCAL PERIOD], MAX('vw360_Dim_InvoiceDate'[FISCAL PERIOD]), DESC)
				)
			)
		lineageTag: dfc978e8-10f0-4fc2-919f-917ec901e876

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

