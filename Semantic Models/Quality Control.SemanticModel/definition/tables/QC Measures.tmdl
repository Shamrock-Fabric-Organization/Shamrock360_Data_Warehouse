	measure 'Candidate Outcome Display' =
			
			VAR CandidateOrder =
			    [Candidate Quality Order ID]
			VAR ThisTest =
			    SELECTEDVALUE ( 'Test Axis'[testid] )
			RETURN
			IF (
			    NOT ISBLANK ( CandidateOrder )
			        && NOT ISBLANK ( ThisTest ),
			    CALCULATE (
			        SELECTEDVALUE ( 'Fact_QualityOrderLineResults'[testresultvalueoutcome] ),
			        REMOVEFILTERS ( 'Fact_QualityOrderLineResults' ),
			        REMOVEFILTERS ( 'Dim_Batch' ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Dim_SerialNumber' ),
			        TREATAS ( { CandidateOrder }, 'Fact_QualityOrderLineResults'[qualityorderid] ),
