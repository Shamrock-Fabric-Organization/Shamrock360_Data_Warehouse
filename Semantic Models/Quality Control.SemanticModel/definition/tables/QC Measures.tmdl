			        REMOVEFILTERS ( 'Dim_SerialNumber' ),
			        TREATAS ( { RefOrder }, 'Fact_QualityOrderLineResults'[qualityorderid] ),
			        TREATAS ( { ThisTest }, 'Fact_QualityOrderLineResults'[testid] )
			    )
			)
		lineageTag: 7ddf52cf-76c9-4988-be58-ae1160e34e73

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Reference Upper Limit' =
			
			VAR RefOrder =
