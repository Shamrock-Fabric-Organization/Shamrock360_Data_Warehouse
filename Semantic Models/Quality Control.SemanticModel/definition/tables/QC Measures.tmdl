	measure 'Reference Test Type' =
			
			VAR HasReferenceRow =
			    [Reference Test Row Count] > 0
			VAR AxisVariable =
			    SELECTEDVALUE ( 'Test Axis'[Default Variable] )
			VAR AxisUnit =
			    SELECTEDVALUE ( 'Test Axis'[Default Unit] )
			RETURN
			SWITCH (
			    TRUE (),
			    NOT HasReferenceRow, BLANK (),
			    NOT ISBLANK ( AxisVariable ), "Outcome",
			    NOT ISBLANK ( AxisUnit ), "Numeric",
			    "Review"
			)
		lineageTag: 4610d247-2709-450c-a37e-fd351ecccb32

