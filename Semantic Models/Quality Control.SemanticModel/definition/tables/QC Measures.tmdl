table 'QC Measures'
	lineageTag: ff91c694-d152-46eb-91c2-886cc9889c3a

	measure 'Reference Selection Count' =
			
			DISTINCTCOUNT ( 'Reference Order'[qualityorderid] )
		formatString: 0
		lineageTag: ddda5c84-0a51-43e8-aed3-46a51cdfb115

	measure 'Reference Quality Order ID' =
			
			SELECTEDVALUE ( 'Reference Order'[qualityorderid] )
		lineageTag: d63320f6-f405-4714-a607-3ce5a1f1d776

	measure 'Reference Order Status' =
			
			SELECTEDVALUE ( 'Reference Order'[QualityOrderStatus] )
		lineageTag: 30bb52c2-f88e-4139-8719-60f41a73eeee

	measure 'Reference Selection Status' =
			
			VAR SelectionCount =
			    [Reference Selection Count]
			VAR BatchFiltered =
			    ISFILTERED ( 'Reference Order'[Batch Number] )
			VAR SerialFiltered =
			    ISFILTERED ( 'Reference Order'[Serial Number] )
			VAR RefStatus =
			    [Reference Order Status]
			RETURN
			SWITCH (
			    TRUE (),
			    SelectionCount = 0,
			        "No reference quality order selected.",
			    SelectionCount = 1 && RefStatus = "Open",
			        "Reference order selected, but it is Open. Use a Pass or Fail quality order as the reference.",
			    SelectionCount = 1,
			        "Reference order selected.",
			    SelectionCount > 1 && BatchFiltered && NOT SerialFiltered,
			        "Batch resolves to multiple quality orders. Select a serial number.",
			    SelectionCount > 1,
			        "Selection is ambiguous. Use Quality Order ID or Batch + Serial."
			)
		lineageTag: 3b3c428a-8447-4c5c-a65c-c8f77fef6514

	measure 'Reference Is Valid' =
			
			VAR SelectionCount =
			    [Reference Selection Count]
			VAR RefStatus =
			    [Reference Order Status]
			RETURN
			IF (
			    SelectionCount = 1
			        && RefStatus <> "Open",
			    1,
			    0
			)
		formatString: 0
		lineageTag: 537452ee-9e07-4a06-a3d5-30d8dc311c49

	measure 'Candidate Quality Order ID' =
			
			SELECTEDVALUE ( 'Candidate Order'[qualityorderid] )
		lineageTag: f2fd2f04-f676-4eae-a360-f8e264b098d7

	measure 'Candidate Order Status' =
			
			SELECTEDVALUE ( 'Candidate Order'[QualityOrderStatus] )
		lineageTag: ff8e590f-bf98-4874-8d9f-3b96ad4653ce

	measure 'Candidate Is Open' =
			
			IF ( [Candidate Order Status] = "Open", 1, 0 )
		formatString: 0
		lineageTag: 08fcdcbe-b1b6-4d0a-85e8-92afff7d302e

	measure 'Reference Test Row Count' =
			
			VAR RefOrder =
			    [Reference Quality Order ID]
			VAR ThisTest =
			    SELECTEDVALUE ( 'Test Axis'[testid] )
			RETURN
			IF (
			    NOT ISBLANK ( RefOrder )
			        && NOT ISBLANK ( ThisTest ),
			    CALCULATE (
			        COUNTROWS ( 'Fact_QualityOrderLineResults' ),
			        REMOVEFILTERS ( 'Fact_QualityOrderLineResults' ),
			        REMOVEFILTERS ( 'Dim_Batch' ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Dim_SerialNumber' ),
			        TREATAS ( { RefOrder }, 'Fact_QualityOrderLineResults'[qualityorderid] ),
			        TREATAS ( { ThisTest }, 'Fact_QualityOrderLineResults'[testid] )
			    )
			)
		formatString: 0
		lineageTag: d94ffd7c-c209-4b2e-9f98-0200e64a7a09

	measure 'Reference Test Skipped Flag' =
			
			VAR RefOrder =
			    [Reference Quality Order ID]
			VAR ThisTest =
			    SELECTEDVALUE ( 'Test Axis'[testid] )
			VAR SkippedRows =
			    CALCULATE (
			        COUNTROWS ( 'Fact_QualityOrderLineResults' ),
			        REMOVEFILTERS ( 'Fact_QualityOrderLineResults' ),
			        REMOVEFILTERS ( 'Dim_Batch' ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Dim_SerialNumber' ),
			        TREATAS ( { RefOrder }, 'Fact_QualityOrderLineResults'[qualityorderid] ),
			        TREATAS ( { ThisTest }, 'Fact_QualityOrderLineResults'[testid] ),
			        'Fact_QualityOrderLineResults'[qmsskiptest] = 1
			    )
			RETURN
			IF ( SkippedRows > 0, 1, 0 )
		formatString: 0
		lineageTag: a75a6e1c-995e-456b-a896-f8a04f8ca0ab

	measure 'Reference Required Test Count' =
			
			VAR RefOrder =
			    [Reference Quality Order ID]
			RETURN
			IF (
			    [Reference Is Valid] = 1,
			    CALCULATE (
			        DISTINCTCOUNT ( 'Order Test Index'[testid] ),
			        REMOVEFILTERS ( 'Order Test Index' ),
			        TREATAS ( { RefOrder }, 'Order Test Index'[qualityorderid] ),
			        'Order Test Index'[IsSkipped] = 0
			    )
			)
		formatString: 0
		lineageTag: b8ba2d22-6d55-49da-8ed8-db30d13a338f

	measure 'Reference Lower Limit' =
			
