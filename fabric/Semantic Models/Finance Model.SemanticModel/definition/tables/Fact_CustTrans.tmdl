	/// Determines the effective “run date” for the aging report. Uses the maximum visible DimDate[Date] in the current filter context (typically “today” via a relative date filter), capped at TODAY() to avoid future dates. Always returns a date (never blank).
	measure 'Report Run Date' = ```
			
			VAR MaxVisibleDate = MAX(Dim_Date[Date])
			-- Safety: if your date table goes into the future, don't accidentally use 12/31/2099.
			RETURN
			COALESCE( MIN( TODAY(), MaxVisibleDate ), TODAY() )
			
			```
		formatString: General Date
		lineageTag: 102a54a5-31f1-4bd5-9b0b-177bbff24b9a

		changedProperty = Name

		changedProperty = Description

	/// Computes the aging “as of” date as the end of the prior month relative to [Report Run Date] (EOMONTH([Report Run Date], -1)). Example: any day in Feb → 1/31. Always returns a date (never blank).
	measure 'Aging As Of Date' = ```
			
			EOMONTH( [Report Run Date], -1 )
			
			```
		formatString: General Date
		lineageTag: 44984a29-13c9-4ccd-b8ee-89e3d6911799

		changedProperty = Name

		changedProperty = Description

	/// Calculates customer open A/R as of [Aging As Of Date] in accounting currency (MST) using amountmst, settleamountmst, closed, and lastsettledate.
	/// 
	/// Includes transactions with TransactionDate <= BalanceDate.
	/// 
	/// Removes DimDate filters to avoid slicing the fact down to only the current day/month.
	/// 
	/// Open-as-of logic:
	/// 
	/// If closed after BalanceDate: treat as fully open as-of (uses full amountmst).
	/// 
	/// If closed on/before BalanceDate: treat as 0.
	/// 
	/// If not closed: uses current open estimate (amountmst - settleamountmst).
	/// Returns 0 when no rows qualify (never blank).
	measure 'Balance as of (MST)' = ```
			
			VAR BalanceDate = [Aging As Of Date]
			
			-- Remove date filters from the model so the page's "today" filter doesn't restrict fact rows.
			VAR BaseRows =
			    CALCULATETABLE(
			        Fact_CustTrans,
			        REMOVEFILTERS(Dim_Date)
			    )
			
			VAR Result =
			    SUMX(
			        FILTER(
			            BaseRows,
			            Fact_CustTrans[TransactionDate] <= BalanceDate
			        ),
			        VAR Amt      = COALESCE(Fact_CustTrans[amountmst], 0)
			        VAR Settled  = COALESCE(Fact_CustTrans[settleamountmst], 0)
			        VAR ClosedN  = COALESCE(Fact_CustTrans[closed], 0)
			        VAR LastSet  = Fact_CustTrans[lastsettledate]
			        VAR IsClosed = ClosedN = 1   -- If your field is TRUE/FALSE, change to: ClosedN = TRUE()
			
			        VAR OpenAsOf =
			            SWITCH(
			                TRUE(),
			                -- Closed after the as-of date: treat as fully open for last-month snapshot purposes
			                IsClosed && NOT ISBLANK(LastSet) && LastSet > BalanceDate, Amt,
			
			                -- Closed on/before the as-of date (or "closed but no date"): not open
			                IsClosed, 0,
			
			                -- Still open: use current open amount
			                Amt - Settled
			            )
			        RETURN
			            OpenAsOf
			    )
			
			RETURN
			COALESCE(Result, 0)
			
			```
		lineageTag: ea6ad0e0-adf7-4e17-af59-017f326a25e2

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Returns the portion of [Balance as of (MST)] that falls into the current Moody’s aging bucket row context using DIM_AgingBuckets[FromDays] and [ToDays].
	/// 
	/// DaysOverdue = DATEDIFF(dueDate, BalanceDate, DAY)
	/// 
	/// Blank due dates are treated as current (DaysOverdue = 0).
	/// 
	/// Removes DimDate filters and evaluates transactions up to BalanceDate.
	/// Uses the same open-as-of logic as [Balance as of (MST)].
	/// Returns 0 when empty (never blank).
	measure 'Aged Balance (MST)' = ```
			
			VAR BalanceDate = [Aging As Of Date]
			VAR MinDays     = MIN(Dim_AgingBuckets[FromDays])
			VAR MaxDays     = MAX(Dim_AgingBuckets[ToDays])
			
			VAR BaseRows =
			    CALCULATETABLE(
			        Fact_CustTrans,
			        REMOVEFILTERS(Dim_Date)
			    )
			
			VAR BucketRows =
			    FILTER(
			        BaseRows,
			        Fact_CustTrans[TransactionDate] <= BalanceDate
			            &&
			        VAR DueDate =
			            Fact_CustTrans[duedate]
			        VAR DaysOverdue =
			            IF(
			                ISBLANK(DueDate),
			                0,  -- missing due date = treat as current
			                DATEDIFF(DueDate, BalanceDate, DAY)
			            )
			        RETURN
			            DaysOverdue >= MinDays
			            && DaysOverdue <= MaxDays
			    )
			
			VAR Result =
			    SUMX(
			        BucketRows,
			        VAR Amt      = COALESCE(Fact_CustTrans[amountmst], 0)
			        VAR Settled  = COALESCE(Fact_CustTrans[settleamountmst], 0)
			        VAR ClosedN  = COALESCE(Fact_CustTrans[closed], 0)
			        VAR LastSet  = Fact_CustTrans[lastsettledate]
			        VAR IsClosed = ClosedN = 1   -- If boolean: ClosedN = TRUE()
			
			        VAR OpenAsOf =
			            SWITCH(
			                TRUE(),
			                IsClosed && NOT ISBLANK(LastSet) && LastSet > BalanceDate, Amt,
			                IsClosed, 0,
			                Amt - Settled
			            )
			        RETURN
			            OpenAsOf
			    )
			
			RETURN
			COALESCE(Result, 0)
			
			```
		lineageTag: 2c9556bf-a2c8-48dd-834a-c23f9f7fad71

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Moody’s “Current (with terms)” bucket (DaysOverdue ≤ 0). Wrapper over [Aged Balance (MST)] filtered to AgingBucketKey = 1. Returns 0 (never blank).
	measure 'CURRENT AMT' = ```
			
			CALCULATE( [Aged Balance (MST)], Dim_AgingBuckets[AgingBucketKey] = 1 )
			
			```
