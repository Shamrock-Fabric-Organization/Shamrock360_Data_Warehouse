	/// Visual filter helper to mimic D365 parameter “Exclude zero balance accounts = Yes”. Returns 1 when [Balance as of] <> 0, else 0. Use as a visual-level filter (= 1). Never blank.
	measure 'Has Nonzero Balance' = ```
			
			VAR Bal = [Balance as of]
			RETURN IF( Bal <> 0, 1, 0 )
			
			```
		formatString: 0
