	/// Computes the mirrored last-year FYTD cutoff date as LY FY Start Date + (Days Into FY - 1), clamped so it does not exceed LY FY End Date. Ensures FYTD comparisons are aligned to the same “day into fiscal year.”
	measure 'ER - LY As Of Date (FY)' =
			
			VAR DayNum = [ER - Days Into FY]
			VAR StartLY = [ER - LY FY Start Date]
			VAR EndLYYear = [ER - LY FY End Date]
			VAR EndCandidate = StartLY + DayNum - 1
			RETURN
			    IF (
			        ISBLANK ( DayNum ) || ISBLANK ( StartLY ),
			        BLANK (),
			        MIN ( EndCandidate, EndLYYear )
			    )
		formatString: General Date
