	/// Returns the first calendar date of the same fiscal period in the prior fiscal year (FY-1), ignoring current date filters.
	measure 'ER - LY Period Start Date' =
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR FP = [ER - Selected Fiscal Period]
			RETURN
			    CALCULATE (
			        MIN ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' ),
			        'Dim_Date'[FiscalYear] = FY - 1,
			        'Dim_Date'[FiscalPeriodNum] = FP
			    )
		formatString: General Date
		lineageTag: 7b6d33ef-2403-4748-8945-87a2025ab5e7

		changedProperty = Name

		changedProperty = Description

	/// Returns the last calendar date of the same fiscal period in the prior fiscal year (FY-1), ignoring current date filters.
	measure 'ER - LY Period End Date' =
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR FP = [ER - Selected Fiscal Period]
			RETURN
			    CALCULATE (
			        MAX ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' ),
			        'Dim_Date'[FiscalYear] = FY - 1,
			        'Dim_Date'[FiscalPeriodNum] = FP
			    )
		formatString: General Date
		lineageTag: 4c5a8766-9b82-4c7c-bbd2-89a5045f46e9

		changedProperty = Name

		changedProperty = Description

	/// Computes the mirrored last-year cutoff date by taking LY Period Start Date + (Days Into Period - 1), then clamping it to not exceed LY Period End Date. Ensures last-year period comparison matches the same day-of-period depth as the current selection.
	measure 'ER - LY As Of Date (Period)' = ```
			
			VAR DayNum = [ER - Days Into Period]
			VAR StartLY = [ER - LY Period Start Date]
			VAR EndLYPeriod = [ER - LY Period End Date]
			VAR EndCandidate = StartLY + DayNum - 1
			RETURN
			    IF (
			        ISBLANK ( DayNum ) || ISBLANK ( StartLY ),
			        BLANK (),
			        MIN ( EndCandidate, EndLYPeriod )
			    )
			
			```
		formatString: General Date
		lineageTag: 2cddd153-1d2f-483d-a84c-8632622ab258

		changedProperty = Name

		changedProperty = Description

	/// Returns the net signed amount between LY Period Start Date and LY As Of Date (Period). This is the “same fiscal period last year, mirrored as-of cutoff” amount.
	measure 'ER - Expense (Period LY AsOf)' = ```
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR FP = [ER - Selected Fiscal Period]
			VAR StartLY = [ER - LY Period Start Date]
			VAR EndLY = [ER - LY As Of Date (Period)]
			RETURN
			    CALCULATE (
			        [ER - Amount (Signed)],
			        DATESBETWEEN ( 'Dim_Date'[Date], StartLY, EndLY ),
			        'Dim_Date'[FiscalYear] = FY - 1,
			        'Dim_Date'[FiscalPeriodNum] = FP
			    )
			
			```
		lineageTag: f1393fef-42b7-451a-8a15-cca6bdd327b5

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Returns the dollar variance between current period as-of and last year period as-of:
	/// Expense (Period AsOf) - Expense (Period LY AsOf).
	measure 'ER - Expense (Period Var $)' =
			
			[ER - Expense (Period AsOf)] - [ER - Expense (Period LY AsOf)]
		lineageTag: 7b83dcf0-094a-49d7-8659-5153bcda5a8d

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Returns the percent variance vs last year for the period:
	/// (Current - LY) / ABS(LY) using DIVIDE for safe handling when LY is zero/blank.
	measure 'ER - Expense (Period Var %)' =
			
			DIVIDE (
			    [ER - Expense (Period Var $)],
			    ABS ( [ER - Expense (Period LY AsOf)] )
			)
		lineageTag: 3a6a6a34-bd76-4ada-b72c-898da68f6f40

