	/// Finds the minimum calendar date in the selected fiscal year and fiscal period, ignoring current date filters (ALL('DimDate')). This reliably returns the true first day of the selected fiscal period.
	measure 'ER - Selected Period Start Date' =
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR FP = [ER - Selected Fiscal Period]
			RETURN
			    CALCULATE (
			        MIN ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' ),
			        'Dim_Date'[FiscalYear] = FY,
			        'Dim_Date'[FiscalPeriodNum] = FP
			    )
		formatString: General Date
		lineageTag: f1488734-269b-453a-9d9b-0ad052bc0c9b

		changedProperty = Name

		changedProperty = Description

	/// Finds the maximum calendar date in the selected fiscal year and fiscal period, ignoring current date filters (ALL('DimDate')). This reliably returns the true last day of the selected fiscal period.
	measure 'ER - Selected Period End Date' =
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR FP = [ER - Selected Fiscal Period]
			RETURN
			    CALCULATE (
			        MAX ( 'Dim_Date'[Date] ),
			        ALL ( 'Dim_Date' ),
			        'Dim_Date'[FiscalYear] = FY,
			        'Dim_Date'[FiscalPeriodNum] = FP
			    )
		formatString: General Date
		lineageTag: 70c67b21-6ed9-4252-9a90-2afc30979b8f

		changedProperty = Name

		changedProperty = Description

	/// Returns the single selected fiscal year from the date slicer (SELECTEDVALUE). Used to anchor all date boundary calculations. Returns blank if multiple years are selected.
	measure 'ER - Selected Fiscal Year' =
			
			SELECTEDVALUE ( 'Dim_Date'[FiscalYear] )
		formatString: 0
		lineageTag: 7a90b572-aa91-4358-b5da-d281739c972b

		changedProperty = Name

		changedProperty = Description

	/// Returns the single selected fiscal period from the slicer (SELECTEDVALUE). Used to anchor all period boundary calculations. Returns blank if multiple periods are selected.
	measure 'ER - Selected Fiscal Period' =
			
			SELECTEDVALUE ( 'Dim_Date'[FiscalPeriodNum] )
		formatString: 0
		lineageTag: f9217881-ef24-4557-b93b-ed1cb4fb061a

		changedProperty = Name

		changedProperty = Description

	/// Chooses the earlier of (a) the selected period end date and (b) yesterday (TODAY()-1). Ensures incomplete current periods stop at yesterday rather than including today or future dates.
	measure 'ER - As Of Date' =
			
			VAR PeriodEnd = [ER - Selected Period End Date]
			VAR Cutoff = TODAY () - 1
			RETURN
			    MIN ( PeriodEnd, Cutoff )
		formatString: General Date
		lineageTag: cc6b1325-99cb-4810-876b-3fa114625f08

		changedProperty = Name

		changedProperty = Description

	/// Returns the number of days from selected period start date through As Of Date (inclusive). Used to create a mirrored “as-of” cutoff for last year’s same fiscal period.
	measure 'ER - Days Into Period' = ```
			
			VAR StartDate = [ER - Selected Period Start Date]
			VAR EndDate = [ER - As Of Date]
			RETURN
			    IF (
			        NOT ISBLANK ( StartDate )
			            && NOT ISBLANK ( EndDate )
			            && EndDate >= StartDate,
			        DATEDIFF ( StartDate, EndDate, DAY ) + 1
			    )
			
			```
		formatString: 0
		lineageTag: 25c71b40-ee6e-4cc9-ae60-4170adee62a8

		changedProperty = Name

		changedProperty = Description

	/// Returns the net signed amount between selected period start date and As Of Date. This is the “current period expense, as-of yesterday” measure.
	measure 'ER - Expense (Period AsOf)' = ```
			
			VAR StartDate = [ER - Selected Period Start Date]
			VAR EndDate = [ER - As Of Date]
			RETURN
			    CALCULATE (
			        [ER - Amount (Signed)],
			        DATESBETWEEN ( 'Dim_Date'[Date], StartDate, EndDate )
			    )
			
			```
		lineageTag: 7a4cac5c-52c3-4654-b799-c6b524196617

		changedProperty = Name

		changedProperty = Description

