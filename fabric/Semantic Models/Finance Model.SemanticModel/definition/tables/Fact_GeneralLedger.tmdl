	/// Returns the signed sum of reporting currency amounts in the current filter context (date, site, dept, GL account, etc.). This is the base building block for all “net” amounts.
	measure 'ER - Amount (Signed)' = ```
			
			SUM ( Fact_GeneralLedger[reportingcurrencyamount] )
			
			```
		lineageTag: 16998b5e-7b26-4edb-ba95-c5439ba3ceb3

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Sums amounts for lines flagged as non-credit (IsCredit = 0) within the current filter context. Does not force the sign; negative debits remain negative.
	measure 'ER - Debit (Period)' =
			
			CALCULATE (
			    SUM ( Fact_GeneralLedger[reportingcurrencyamount]),
			    Fact_GeneralLedger[iscredit] = 0
			)
		lineageTag: 8aab7f3e-9364-4023-9efb-492ab8fc61ce

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Sums amounts for lines flagged as credit (IsCredit = 0) and multiplies by -1 so credits display with the “trial balance style” sign convention (credits typically show positive, but can show negative if the underlying credit amount is positive).
	measure 'ER - Credit (Period)' =
			
			- CALCULATE (
			    SUM ( Fact_GeneralLedger[reportingcurrencyamount] ),
			    Fact_GeneralLedger[iscredit] = 1
			)
		lineageTag: db5cc04f-c2f1-4fe7-95b3-a56ed126c65e

		changedProperty = Name

		changedProperty = Description

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ER - Opening Balance' = ```
			
			VAR StartDate =
			    MIN ( 'Dim_Date'[Date] )
			RETURN
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER (
			            ALL ( 'Dim_Date'[Date] ),
			            'Dim_Date'[Date] < StartDate
			        )
			    )
			
			```
		lineageTag: 18b014b8-8969-4d8d-a6a3-05b28b0e3988

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ER - Closing Balance' = ```
			
			[ER - Opening Balance V3] + [ER - Debit (Period)] - [ER - Credit (Period)]
			
			```
		lineageTag: 3a9388fd-4152-4c65-afc2-c7d9d8f55e48

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ER - Closing Balance (Running)' = ```
			
			VAR EndDate =
			    MAX ( 'Dim_Date'[Date] )
			RETURN
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER (
			            ALL ( 'Dim_Date'[Date] ),
			            'Dim_Date'[Date] <= EndDate
			        )
			    )
			
			```
		lineageTag: 31231765-124b-4cc0-8de5-6f834f5e1adc

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Net Change (Period)
	/// Computes net activity for the period as Debit (Period) - Credit (Period). Intended as “net expense movement” in the selected period.
	measure 'ER - Net Change (Period)' = ```
			
			[ER - Debit (Period)] - [ER - Credit (Period)]
			
			```
		lineageTag: 3f201db2-6b4f-4f34-bf61-af0431483ae8

		changedProperty = Name

