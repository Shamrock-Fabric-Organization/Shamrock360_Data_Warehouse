	measure 'ER - Opening Balance V2' = ```
			
			
			VAR StartDate =
			    MIN ( 'Dim_Date'[Date] )
			
			VAR StartFiscalYear =
			    CALCULATE (
			        MAX ( 'Dim_Date'[FiscalYear] ),
			        FILTER ( ALL ( 'Dim_Date' ), 'Dim_Date'[Date] = StartDate )
			    )
			
			VAR FYStartDate =
			    CALCULATE (
			        MIN ( 'Dim_Date'[Date] ),
			        FILTER (
			            ALL ( 'Dim_Date' ),
			            'Dim_Date'[FiscalYear] = StartFiscalYear
			                && 'Dim_Date'[FiscalDayNum] = 1
			        )
			    )
			
			-- Carry-forward accounts: life-to-date before StartDate
			VAR CarryForwardOpen =
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER ( ALL ( 'Dim_Date' ), 'Dim_Date'[Date] < StartDate ),
			        KEEPFILTERS (
			            FILTER (
			                ALL ( 'Dim_GL_Account' ),
			                NOT ( 'Dim_GL_Account'[Account_Type_Description]
			                    -- IN { "ProfitAndLoss" } 
			                    IN { "ProfitAndLoss", "Revenue" } 
			                    )
			            )
			        )
			    )
			
			-- P&L accounts: FY-to-date before StartDate
			VAR PL_Open =
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER (
			            ALL ( 'Dim_Date' ),
			            'Dim_Date'[Date] >= FYStartDate
			                && 'Dim_Date'[Date] < StartDate
			        ),
			        KEEPFILTERS (
			            FILTER (
			                ALL ( 'Dim_GL_Account' ),
			                'Dim_GL_Account'[Account_Type_Description]
			                    -- IN { "ProfitAndLoss" }
			                    IN { "ProfitAndLoss", "Revenue" }
			            )
			        )
			    )
			
			RETURN
			    -- COALESCE ( CarryForwardOpen, 0 ) + COALESCE ( PL_Open, 0 )
			    CarryForwardOpen + PL_Open
			
			```
		lineageTag: 6b36de97-955b-469c-b198-4f836e3816fe

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ER - Opening Balance V3' = ```
			
			
			
			VAR StartDate =
			    MIN ( 'Dim_Date'[Date] )
			
			VAR StartFiscalYear =
			    CALCULATE (
			        MAX ( 'Dim_Date'[FiscalYear] ),
			        FILTER ( ALL ( 'Dim_Date' ), 'Dim_Date'[Date] = StartDate )
			    )
			
			-- 1) Opening-period entries: include them up to AND INCLUDING StartDate
			--    (critical for the first day of the fiscal year)
			VAR OpeningEntries =
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER (
			            ALL ( 'Dim_Date' ),
			            'Dim_Date'[FiscalYear] = StartFiscalYear
			                && 'Dim_Date'[Date] <= StartDate
			        ),
			        Fact_GeneralLedger[FiscalCalendarPeriodType_$label] = "Opening"
			    )
			
			-- 2) Everything else before StartDate (normal activity)
			VAR NonOpeningBeforeStart =
			    CALCULATE (
			        [ER - Amount (Signed)],
			        FILTER (
			            ALL ( 'Dim_Date' ),
			            'Dim_Date'[FiscalYear] = StartFiscalYear
			                && 'Dim_Date'[Date] < StartDate
			        ),
			        Fact_GeneralLedger[FiscalCalendarPeriodType_$label] <> "Opening"
			    )
			
			RETURN
			    -- COALESCE ( OpeningEntries, 0 ) + COALESCE ( NonOpeningBeforeStart, 0 )
			    OpeningEntries + NonOpeningBeforeStart
			
			```
		lineageTag: 21d8bb7a-c867-47c7-8443-9523ac4f5a4e

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

