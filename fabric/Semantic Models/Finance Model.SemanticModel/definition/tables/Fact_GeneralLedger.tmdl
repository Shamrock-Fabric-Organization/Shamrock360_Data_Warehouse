	/// Returns the number of days from FY Start Date through As Of Date (inclusive). Used to build a mirrored last-year FYTD cutoff date.
	measure 'ER - Days Into FY' = ```
			
			VAR FYStart = [ER - FY Start Date]
			VAR EndDate = [ER - As Of Date]
			RETURN
			    IF (
			        NOT ISBLANK ( FYStart )
			            && NOT ISBLANK ( EndDate )
			            && EndDate >= FYStart,
			        DATEDIFF ( FYStart, EndDate, DAY ) + 1
			    )
			
