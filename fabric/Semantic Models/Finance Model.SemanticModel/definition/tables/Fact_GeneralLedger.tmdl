	measure 'ER - Expense (FYTD LY AsOf)' = ```
			
			VAR FY = [ER - Selected Fiscal Year]
			VAR StartLY = [ER - LY FY Start Date]
			VAR EndLY = [ER - LY As Of Date (FY)]
			RETURN
			    CALCULATE (
			        [ER - Amount (Signed)],
