	measure 'Weekly Average Revenue (Sales Days)' = ```
			
			
			VAR wkStart =
			    SELECTEDVALUE ( Dim_Date[WeekStartDate] )
			RETURN
			IF (
			    ISBLANK ( wkStart ),
			    BLANK (),
			    VAR wkEnd = wkStart + 6
			
			    VAR TodayDate = TODAY ()
			    VAR NowEST =
			        NOW() - TIME ( 5, 0, 0 )   -- adjust to EST (or 4 for EDT)
			
			    VAR AfterCutoffToday =
			        NowEST >= ( TodayDate + TIME ( 19, 0, 0 ) )
			
			    -- Dates in the selected week, excluding future days,
			    -- and excluding "today" until after 7PM
			    VAR WeekDatesEligible =
			        FILTER (
			            DATESBETWEEN ( Dim_Date[Date], wkStart, wkEnd ),
			            Dim_Date[Date] <= TodayDate
			                && ( Dim_Date[Date] < TodayDate || AfterCutoffToday )
			        )
			
			    VAR TrackedSites =
			        FILTER (
			            ALL ( Dim_Warehouse ),
			            CONTAINSSTRING ( Dim_Warehouse[Site_Name], "Kentucky" )
			                || CONTAINSSTRING ( Dim_Warehouse[Site_Name], "New Jersey" )
			                || CONTAINSSTRING ( Dim_Warehouse[Site_Name], "South Carolina" )
			        )
			
			    -- Numerator: all eligible dates in the week (Mon-Sun),
			    -- so weekend catch-up is included in the week's total
			    VAR RevenueIncluded =
			        CALCULATE (
			            [SalesAmount],
			            WeekDatesEligible,
			            KEEPFILTERS ( TrackedSites )
			        )
			
			    -- Denominator: only Mon-Fri dates with any records/orders
			    VAR WeekdayOrderDays =
			        FILTER (
			            WeekDatesEligible,
			            WEEKDAY ( Dim_Date[Date], 2 ) <= 5
			                && CALCULATE ( [Total Orders], KEEPFILTERS ( TrackedSites ) ) > 0
			        )
			
			    VAR SalesDaysIncluded =
			        COUNTROWS ( WeekdayOrderDays )
			
			    RETURN
			        DIVIDE ( RevenueIncluded, SalesDaysIncluded )
			)
			
			```
		lineageTag: a8e5b858-5f3f-4f23-9bca-03178303348d

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OOO - Invoiced + Open Quantity – Selected Period' = ```
			
			VAR StartDate =
			    [BaseMonthStart]
			VAR EndDate =
			    [BaseMonthEnd]
			
			-- Only this month's invoiced amount (by invoice date)
			VAR ClosedAmtSelectedPeriod =
			    CALCULATE (
			        (SUM ( Fact_Customer_Invoices[Quantity_LBs])),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[Date] >= StartDate &&
			            Dim_Date[Date] <= EndDate
			        )
			    )
			
			-- Open amount for all orders with requested ship date up to *end* of month
			VAR OpenAmtUpToPeriod_ReqShip =
			    CALCULATE (
			        SUM ( Fact_Sales[Quantity_LBs] ),
			        Fact_Sales[SalesLine_Status] IN { "Open", "Delivered" },
			        USERELATIONSHIP (
			            Fact_Sales[SalesLine_RequestedShipDateKey],
			            Dim_Date[DateKey]
			        ),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[Date] <= EndDate        -- cumulative up to the end of the selected month
			        )
			    )
			
			RETURN
			    ClosedAmtSelectedPeriod + OpenAmtUpToPeriod_ReqShip
			
			```
		lineageTag: b0b76134-18d9-4a8f-931e-1383f40809cd

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OOO - Invoiced + Open Amount – Selected Period' = ```
			
			VAR StartDate =
			    [BaseMonthStart]
			VAR EndDate =
			    [BaseMonthEnd]
			
			-- Only this month's invoiced amount (by invoice date)
			VAR ClosedAmtSelectedPeriod =
			    CALCULATE (
			        (SUM ( Fact_Customer_Invoices[LineAmount]) + SUM(Fact_Customer_Invoices[Fuel_Charge]) + SUM(Fact_Customer_Invoices[Freight]) + SUM(Fact_Customer_Invoices[PLT_Brk_Ch]) + SUM(Fact_Customer_Invoices[Tariff_SC])),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[Date] >= StartDate &&
			            Dim_Date[Date] <= EndDate
			        )
			    )
			
			-- Open amount for all orders with requested ship date up to *end* of month
			VAR OpenAmtUpToPeriod_ReqShip =
			    CALCULATE (
			        SUM ( Fact_Sales[Amount] ),
			        Fact_Sales[SalesLine_Status] IN { "Open", "Delivered" },
			        USERELATIONSHIP (
			            Fact_Sales[SalesLine_RequestedShipDateKey],
			            Dim_Date[DateKey]
			        ),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[Date] <= EndDate        -- cumulative up to the end of the selected month
			        )
			    )
			
			RETURN
			    ClosedAmtSelectedPeriod + OpenAmtUpToPeriod_ReqShip
			
			```
