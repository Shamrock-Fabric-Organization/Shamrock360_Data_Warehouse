	measure 'Moving Avg (4 Weeks)' = ```
			
			VAR CurrentWeek =
			    MAX ( 'Dim_Date'[WeekStartDate] )
			VAR Last4Weeks =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( 'Dim_Date'[WeekStartDate] ),
			            'Dim_Date'[WeekStartDate] <= CurrentWeek
			        ),
			        'Dim_Date'[WeekStartDate],
			        DESC
			    )
			RETURN
			AVERAGEX ( Last4Weeks, [Weekly Average Revenue (Sales Days)] )
			
			```
		lineageTag: b886cf22-be56-486c-896c-cfa905223f89

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Moving Avg (3 Months)' = ```
			
			VAR ThisWeek =
			    MAX ( 'Dim_Date'[WeekStartDate] )
			
			-- first day of the month 3 months before current month
			VAR WindowStart =
			    EOMONTH ( ThisWeek, -3 ) + 1
			
			VAR WeeksInRange =
			    FILTER (
			        ALL ( 'Dim_Date'[WeekStartDate] ),
			        'Dim_Date'[WeekStartDate] >= WindowStart
			            && 'Dim_Date'[WeekStartDate] <= ThisWeek
			    )
			RETURN
			AVERAGEX ( WeeksInRange, [Weekly Average Revenue (Sales Days)] )
			
			```
