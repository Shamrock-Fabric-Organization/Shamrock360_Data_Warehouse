	measure 'Monthly Avg Revenue (30-day)' = ```
			
			VAR RevenuePerMonth =
			    CALCULATE (
			        [SalesAmount],
			        ALLEXCEPT ( 'Dim_Date', 'Dim_Date'[MonthStartDate] )
			    )
			RETURN
			DIVIDE ( RevenuePerMonth, 30 )
			
