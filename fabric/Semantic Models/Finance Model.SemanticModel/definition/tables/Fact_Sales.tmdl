		changedProperty = Name

	measure 'Order Book Lifecycle Sales Amount' =
			
			VAR _Bucket =
			    SELECTEDVALUE ( 'Order Lifecycle Bucket'[LifecycleBucket] )
			RETURN
			SWITCH (
			    _Bucket,
			
			    "Invoiced",
			        CALCULATE (
			            [Gross Sales Activity Amount],
			            USERELATIONSHIP (
			                'Fact_Sales'[InvoiceDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] = "Invoiced" ),
			            KEEPFILTERS ( NOT ISBLANK ( 'Fact_Sales'[InvoiceDateKey] ) ),
			            KEEPFILTERS ( 'Fact_Sales'[InvoiceDateKey] <> 19000101 ),
			            KEEPFILTERS ( 'Fact_Sales'[InvoiceDateKey] <> 0 )
			        ),
			
			    "Open - Confirmed",
			        CALCULATE (
			            [Gross Sales Activity Amount],
			            USERELATIONSHIP (
			                'Fact_Sales'[SalesLine_ShipDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Invoiced" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Canceled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Cancelled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "None" ),
			            KEEPFILTERS ( NOT ISBLANK ( 'Fact_Sales'[SalesLine_ShipDateKey] ) ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_ShipDateKey] <> 19000101 ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_ShipDateKey] <> 0 )
			        ),
			
			    "Open - Requested",
			        CALCULATE (
			            [Gross Sales Activity Amount],
			            USERELATIONSHIP (
			                'Fact_Sales'[SalesLine_RequestedShipDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Invoiced" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Canceled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Cancelled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "None" ),
			            KEEPFILTERS (
			                ISBLANK ( 'Fact_Sales'[SalesLine_ShipDateKey] )
			                    || 'Fact_Sales'[SalesLine_ShipDateKey] = 19000101
			                    || 'Fact_Sales'[SalesLine_ShipDateKey] = 0
			            )
			        )
			)
		lineageTag: 818ab21f-1f64-4723-9274-c1ac0c715648

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Order Book Lifecycle Quantity LBs' =
			
			VAR _Bucket =
			    SELECTEDVALUE ( 'Order Lifecycle Bucket'[LifecycleBucket] )
			RETURN
			SWITCH (
			    _Bucket,
			
			    "Invoiced",
			        CALCULATE (
			            [Gross Sales Activity Quantity (LBs)],
			            USERELATIONSHIP (
			                'Fact_Sales'[InvoiceDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] = "Invoiced" ),
			            KEEPFILTERS ( NOT ISBLANK ( 'Fact_Sales'[InvoiceDateKey] ) ),
			            KEEPFILTERS ( 'Fact_Sales'[InvoiceDateKey] <> 19000101 ),
			            KEEPFILTERS ( 'Fact_Sales'[InvoiceDateKey] <> 0 )
			        ),
			
			    "Open - Confirmed",
			        CALCULATE (
			            [Gross Sales Activity Quantity (LBs)],
			            USERELATIONSHIP (
			                'Fact_Sales'[SalesLine_ShipDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Invoiced" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Canceled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Cancelled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "None" ),
			            KEEPFILTERS ( NOT ISBLANK ( 'Fact_Sales'[SalesLine_ShipDateKey] ) ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_ShipDateKey] <> 19000101 ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_ShipDateKey] <> 0 )
			        ),
			
			    "Open - Requested",
			        CALCULATE (
			            [Gross Sales Activity Quantity (LBs)],
			            USERELATIONSHIP (
			                'Fact_Sales'[SalesLine_RequestedShipDateKey],
			                'Dim_Date_Secondary'[DateKey]
			            ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Invoiced" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Canceled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "Cancelled" ),
			            KEEPFILTERS ( 'Fact_Sales'[SalesLine_Status] <> "None" ),
			            KEEPFILTERS (
			                ISBLANK ( 'Fact_Sales'[SalesLine_ShipDateKey] )
			                    || 'Fact_Sales'[SalesLine_ShipDateKey] = 19000101
			                    || 'Fact_Sales'[SalesLine_ShipDateKey] = 0
			            )
			        )
			)
		lineageTag: dc929c6f-c7cc-4236-94fe-837a040ed7a4

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Sales Activity Amount' =
			
			CALCULATE (
			    SUM ( Fact_Sales[Amount] ),
			    KEEPFILTERS ( Fact_Sales[Amount] > 0 )
			)
		lineageTag: 1a739670-f223-4fc0-bd6a-7f2e2faba7f7

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Gross Sales Activity Quantity (LBs)' =
			
			CALCULATE (
			    SUM ( Fact_Sales[Quantity_LBs] ),
			    KEEPFILTERS ( Fact_Sales[Quantity_LBs] > 0 )
			)
		lineageTag: cd5aea0f-5a4e-43e9-a63b-440f9987e2e7

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Selected Order Lifecycle Metric' =
			
			VAR _Metric =
			    SELECTEDVALUE ( 'Order Book Metric Selector'[Metric] )
			RETURN
			SWITCH (
			    _Metric,
			    "Revenue", [Order Book Lifecycle Sales Amount],
			    "Quantity", [Order Book Lifecycle Quantity LBs],
			    BLANK ()
			)
		lineageTag: df74f200-5c5f-4803-a965-83324a9684bd

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Selected Order Intake Metric' =
			
			VAR _Metric =
			    SELECTEDVALUE ( 'Order Book Metric Selector'[Metric] )
			RETURN
			SWITCH (
			    _Metric,
			    "Revenue", [Gross Sales Activity Amount],
			    "Quantity", [Gross Sales Activity Quantity (LBs)],
			    BLANK ()
			)
		lineageTag: d51369bb-6029-4c33-884e-89e55305566b

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Negative Sales Activity Amount' =
			
			CALCULATE (
			    SUM ( Fact_Sales[Amount] ),
			    KEEPFILTERS ( Fact_Sales[Amount] < 0 )
			)
		lineageTag: c3250434-caeb-4b05-b210-6166c6f3e8b2

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Negative Sales Activity Quantity' =
			
			CALCULATE (
			    SUM ( Fact_Sales[Quantity_LBs] ),
			    KEEPFILTERS ( Fact_Sales[Quantity_LBs] < 0 )
			)
		lineageTag: 17274753-06ee-40ed-bdbf-029e182af7c7

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Selected Negative Sales Metric' =
			
			VAR _Metric =
			    SELECTEDVALUE ( 'Order Book Metric Selector'[Metric] )
			RETURN
			SWITCH (
			    _Metric,
			    "Revenue", [Negative Sales Activity Amount],
			    "Quantity", [Negative Sales Activity Quantity],
			    BLANK ()
			)
		lineageTag: 72234e8f-8044-4d53-8583-495dc642ad7f

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

