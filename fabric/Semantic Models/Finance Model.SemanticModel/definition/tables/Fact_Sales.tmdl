	measure 'Is Confirmed Open Order (All Dates)' =
			
			VAR EndDate  = [BaseMonthEnd]
			VAR NullDate = DATE ( 2025, 10, 30 )
			
			VAR IsDetailRow =
			    ISINSCOPE ( Fact_Sales[Customer_Order_Number] )
			
			VAR ConfirmedRows =
			    CALCULATE (
			        COUNTROWS ( Fact_Sales ),
			        Fact_Sales[SalesLine_Status] = "Open",
			        USERELATIONSHIP ( Fact_Sales[SalesLine_ShipDateKey], Dim_Date[DateKey] ),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[Date] >= NullDate
			        )
			    )
			
			RETURN
			    IF (
			        NOT IsDetailRow,
			        BLANK (),
			        IF ( ConfirmedRows > 0, 1, BLANK () )
			    )
		formatString: 0
