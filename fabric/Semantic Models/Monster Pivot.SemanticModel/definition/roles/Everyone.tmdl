role Everyone
	modelPermission: read

	tablePermission 'Sales Table' = [Sales Status] == "Invoiced"

	tablePermission 'Employee Table' = COUNTROWS ( RELATEDTABLE ( 'Sales Table' ) ) > 0

	tablePermission 'Product Table' = COUNTROWS ( RELATEDTABLE ( 'Sales Table' ) ) > 0

	tablePermission 'Date Table' =
			-- Date table RLS
			'Date Table'[Fiscal Year] >= 2025
			    && COUNTROWS ( RELATEDTABLE ( 'Sales Table' ) ) > 0

	tablePermission 'Legal Entity Table' = [Entity ID] == "101"

	tablePermission 'Account Table' = COUNTROWS ( RELATEDTABLE ( 'Sales Table' ) ) > 0

	tablePermission 'Warehouse Table' = COUNTROWS ( RELATEDTABLE ( 'Sales Table' ) ) > 0

	annotation PBI_Id = 8019e170c24948d2bf6a2eb4e49ad7dd

