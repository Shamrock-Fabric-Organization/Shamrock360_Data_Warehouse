		isHidden
		lineageTag: 79aefc5b-dd2e-4d35-b175-d8d2bde64ae9

		changedProperty = Name

		changedProperty = IsHidden

	measure 'Valid YoY Selection' =
			
			IF (
			    NOT ISBLANK ( [Selected Fiscal Year] )
			        && NOT ISBLANK ( [Selected Fiscal Period] ),
			    1,
			    0
			)
		formatString: 0
		isHidden
