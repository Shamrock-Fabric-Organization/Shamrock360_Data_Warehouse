	dataCategory: Time

	measure 'Selected Fiscal Year' =
			
			SELECTEDVALUE ( 'Date Table'[Fiscal Year] )
		formatString: 0
		isHidden
		lineageTag: ea74d0cc-cca4-49b4-accc-8f57c6dde5ee

		changedProperty = Name

		changedProperty = IsHidden

	measure 'Prior Fiscal Year' =
			
			VAR _fy = [Selected Fiscal Year]
			RETURN
			    IF ( NOT ISBLANK ( _fy ), _fy - 1 )
		formatString: 0
		isHidden
		lineageTag: e5bc8f88-c401-4307-bfbe-8f59af47dff4

		changedProperty = Name

		changedProperty = IsHidden

	measure 'Selected Fiscal Period' =
			
