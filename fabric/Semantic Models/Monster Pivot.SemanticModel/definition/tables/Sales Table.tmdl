	measure 'Direct Std Cost Dollar' =
			
			SUMX (
			    'Sales Table',
			    VAR _qty = 'Sales Table'[Quantity_LBs]
			    VAR _directStd =
			        COALESCE ( RELATED ( Dim_StandardCost[Total_Direct_Cost_Standard] ), 0 )
			    VAR _packagingStd =
			        COALESCE ( RELATED ( Dim_StandardCost[Packaging_Cost_Standard] ), 0 )
			    RETURN
			        _qty * ( _directStd + _packagingStd )
			)
		isHidden
		lineageTag: bed06d5f-b8bc-47fb-a9fa-66dd8cd657ad

		changedProperty = Name

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Overhead Std Cost Dollar' =
			
			SUMX (
			    'Sales Table',
			    VAR _qty = 'Sales Table'[Quantity_LBs]
			    VAR _overheadStd =
			        COALESCE ( RELATED ( Dim_StandardCost[Total_Overhead_Cost_Standard] ), 0 )
			    RETURN
			        _qty * _overheadStd
			)
		isHidden
		lineageTag: 0affeab2-23cd-45cd-83be-ae4235b0db8c

		changedProperty = Name

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Std Cost Dollar' =
			
			SUMX (
			    'Sales Table',
			    VAR _qty = 'Sales Table'[Quantity_LBs]
			    VAR _totalStd =
			        COALESCE ( RELATED ( Dim_StandardCost[TotalCost] ), 0 )
			    RETURN
			        _qty * _totalStd
			)
		isHidden
		lineageTag: f8cdaf13-f476-4630-8f88-6fa39dd72a2f

