	measure 'Vol Percent Delta' =
			
			VAR _py = [Vol LBS PY]
			VAR _delta = [Vol Delta]
			VAR _result = DIVIDE ( _delta, _py )
			RETURN
			    IF (
			        OR ( ISBLANK ( _result ), _result = 0 ),
			        BLANK (),
			        _result
			    )
		formatString: #,0.00%;-#,0.00%;#,0.00%
