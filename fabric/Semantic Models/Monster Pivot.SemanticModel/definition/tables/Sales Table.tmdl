	measure 'Vol LBS PY' =
			
			VAR _valid = [Valid YoY Selection]
			VAR _fy = [Prior Fiscal Year]
			VAR _fp = [Selected Fiscal Period]
			RETURN
			    IF (
			        _valid <> 1,
			        BLANK(),
			        CALCULATE (
			            [Qty LBS],
			            REMOVEFILTERS ( 'Date Table'[Fiscal Year], 'Date Table'[Fiscal Period] ),
			            'Date Table'[Fiscal Year] = _fy,
			            'Date Table'[Fiscal Period] <= _fp
			        )
			    )
		formatString: 0
		lineageTag: d60e88d0-f895-4f57-a5e6-efb58c581654

		changedProperty = Name

		changedProperty = FormatString

