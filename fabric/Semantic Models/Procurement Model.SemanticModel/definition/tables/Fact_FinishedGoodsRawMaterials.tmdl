	measure FinishedGoodName = ```
			
			VAR dk = VALUES ( 'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey] )
			RETURN
			CALCULATE (
			    SELECTEDVALUE ( 'Dim_Product'[Product_Name]),
			    -- neutralize any existing Dim_Date filter coming from the active relationship
			    REMOVEFILTERS ( 'Dim_Product' ),
			    -- apply the requested-ship keys as a filter on the date dimension
			    TREATAS ( dk, 'Dim_Product'[ProductKey] )
			)
			
			```
		lineageTag: 2bf44a36-b94b-4630-8138-876f3d9e9b0e

		changedProperty = Name

