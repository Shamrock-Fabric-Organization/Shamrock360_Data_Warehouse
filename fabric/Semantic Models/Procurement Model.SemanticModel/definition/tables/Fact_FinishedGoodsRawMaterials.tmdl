	measure RMPerFG = SUM(Fact_FinishedGoodsRawMaterials[RawMaterialAmtPerLbFG])
		lineageTag: a38310a3-01ae-4d16-b0fd-c919c222ca7b

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RMHT - Show FG Detail' =
			
			IF (
			    HASONEVALUE ( 'Dim_Product'[Product_ID] )
			        || HASONEVALUE ( 'Dim_Product'[ProductKey] ),
			    1
			)
		formatString: 0
		lineageTag: 11694f11-82af-430f-9ce2-b5d535517311

		changedProperty = Name

	measure 'RMHT - FG Sold LBs for Selected RM' =
			
			VAR ValidFormulaSites =
			    FILTER (
			        ALL ( 'Fact_FinishedGoodsRawMaterials'[RmSiteId] ),
			        'Fact_FinishedGoodsRawMaterials'[RmSiteId] <> "90"
			    )
			
			VAR FinishedGoodKeys =
			    CALCULATETABLE (
			        VALUES ( 'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey] ),
			        REMOVEFILTERS ( 'DIM_Site' ),
			        ValidFormulaSites
			    )
			
			RETURN
			    IF (
			        [RMHT - Show FG Detail] = 1
			            && COUNTROWS ( FinishedGoodKeys ) > 0,
			        CALCULATE (
			            [Quantity LBs],
			            REMOVEFILTERS ( 'Dim_Product' ),
			            REMOVEFILTERS ( 'Dim_Date' ),
			            TREATAS (
			                FinishedGoodKeys,
			                'Dim_Product'[ProductKey]
			            )
			        )
			    )
		lineageTag: d3de93b9-e3f9-4206-9c50-f4f4fd38262d

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RMHT - RM Per Lb FG' =
			
			DIVIDE (
			    [RMHT - Theoretical RM Demand by FG LBs],
			    [RMHT - FG Sold LBs for Selected RM]
			)
		lineageTag: 811b1c60-4d28-432a-b916-070435314ccf

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RMHT - Theoretical RM Demand by FG LBs' =
			
			VAR ValidFormulaSites =
			    FILTER (
			        ALL ( 'Fact_FinishedGoodsRawMaterials'[RmSiteId] ),
			        'Fact_FinishedGoodsRawMaterials'[RmSiteId] <> "90"
			    )
			
			VAR FinishedGoodKeys =
			    CALCULATETABLE (
			        VALUES ( 'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey] ),
			        REMOVEFILTERS ( 'DIM_Site' ),
			        ValidFormulaSites
			    )
			
			RETURN
			    IF (
			        [RMHT - Show FG Detail] = 1,
			        SUMX (
			            FinishedGoodKeys,
			            VAR ThisFinishedGoodKey =
			                'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey]
			
			            VAR ThisRMPerLbFG =
			                CALCULATE (
			                    SUM ( 'Fact_FinishedGoodsRawMaterials'[RawMaterialAmtPerLbFG] ),
			                    REMOVEFILTERS ( 'DIM_Site' ),
			                    ValidFormulaSites,
			                    'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey] = ThisFinishedGoodKey
			                )
			
			            VAR FinishedGoodSoldLbs =
			                CALCULATE (
			                    [Quantity LBs],
			                    REMOVEFILTERS ( 'Dim_Product' ),
			                    REMOVEFILTERS ( 'Dim_Date' ),
			                    TREATAS (
			                        { ThisFinishedGoodKey },
			                        'Dim_Product'[ProductKey]
			                    )
			                )
			
			            RETURN
			                FinishedGoodSoldLbs * ThisRMPerLbFG
			        )
			    )
		lineageTag: 4f0eaa51-72fd-4b23-9f1f-994880fcdca1

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'RMHT - RM Demand Share %' =
			
			DIVIDE (
			    [RMHT - Theoretical RM Demand by FG LBs],
			    [Historical RM Demand LBs]
			)
		lineageTag: 7275421c-8f89-4645-b0a3-8d1213165056

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

