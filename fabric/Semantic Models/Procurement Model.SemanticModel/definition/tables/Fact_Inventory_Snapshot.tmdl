table Fact_Inventory_Snapshot
	lineageTag: bbcedbff-162f-458e-9685-28f109d8635a
	sourceLineageTag: [dbo].[mtbl_EDW_Fact_Inventory_Snapshot]

	defaultDetailRowsDefinition = ```
			DEFINE 
			---- MODEL MEASURES BEGIN ----
			MEASURE Fact_Inventory_Snapshot[Available for Reservation] = (([Posted Quantity] + [Received Qty] - [Deducted Qty] + [Registered Qty] - [Picked Qty]) - [Physical Reserved])
			MEASURE Fact_Inventory_Snapshot[Available for Reservation LBs] = (([Posted Quantity LBs] + [Received Qty LBs] - [Deducted Qty LBs] + [Registered Qty LBs] - [Picked Qty LBs]) - [Physical Reserved LBs])
			MEASURE Fact_Inventory_Snapshot[Available Physical] = SUM(Fact_Inventory_Snapshot[availphysical])
			MEASURE Fact_Inventory_Snapshot[Available Physical LBs] = SUM(Fact_Inventory_Snapshot[availphysical_LBs])
			MEASURE Fact_Inventory_Snapshot[Deducted Qty] = SUM(Fact_Inventory_Snapshot[deducted])
			MEASURE Fact_Inventory_Snapshot[Deducted Qty LBs] = SUM(Fact_Inventory_Snapshot[deducted_LBs])
			MEASURE Fact_Inventory_Snapshot[On Order] = SUM(Fact_Inventory_Snapshot[onorder])
			MEASURE Fact_Inventory_Snapshot[On Order LBs] = SUM(Fact_Inventory_Snapshot[onorder_LBs])
			MEASURE Fact_Inventory_Snapshot[Ordered Qty] = SUM(Fact_Inventory_Snapshot[ordered])
			MEASURE Fact_Inventory_Snapshot[Ordered Qty LBs] = SUM(Fact_Inventory_Snapshot[ordered_LBs])
			MEASURE Fact_Inventory_Snapshot[Ordered Reserved] = SUM(Fact_Inventory_Snapshot[reservordered])
			MEASURE Fact_Inventory_Snapshot[Ordered Reserved LBs] = SUM(Fact_Inventory_Snapshot[reservordered_LBs])
			MEASURE Fact_Inventory_Snapshot[Physical Inventory] = SUM('Fact_Inventory_Snapshot'[physicalinvent])
			MEASURE Fact_Inventory_Snapshot[Physical Inventory LBs] = SUM(Fact_Inventory_Snapshot[physicalinvent_LBs])
			MEASURE Fact_Inventory_Snapshot[Physical Reserved] = SUM(Fact_Inventory_Snapshot[reservphysical])
			MEASURE Fact_Inventory_Snapshot[Physical Reserved LBs] = SUM(Fact_Inventory_Snapshot[reservphysical_LBs])
			MEASURE Fact_Inventory_Snapshot[Picked Qty] = SUM(Fact_Inventory_Snapshot[picked])
			MEASURE Fact_Inventory_Snapshot[Picked Qty LBs] = SUM(Fact_Inventory_Snapshot[picked_LBs])
			MEASURE Fact_Inventory_Snapshot[Posted Quantity] = SUM(Fact_Inventory_Snapshot[postedqty])
			MEASURE Fact_Inventory_Snapshot[Posted Quantity LBs] = SUM(Fact_Inventory_Snapshot[postedqty_LBs])
			MEASURE Fact_Inventory_Snapshot[Received Qty] = SUM(Fact_Inventory_Snapshot[received])
			MEASURE Fact_Inventory_Snapshot[Received Qty LBs] = SUM(Fact_Inventory_Snapshot[received_LBs])
			MEASURE Fact_Inventory_Snapshot[Registered Qty] = SUM(Fact_Inventory_Snapshot[registered])
			MEASURE Fact_Inventory_Snapshot[Registered Qty LBs] = SUM(Fact_Inventory_Snapshot[registered_LBs])
			MEASURE Fact_Inventory_Snapshot[Total Available] = ([Available for Reservation] + [Ordered Qty] - [On Order] - [Ordered Reserved])
			MEASURE Fact_Inventory_Snapshot[Total Available LBs] = ([Available for Reservation LBs] + [Ordered Qty LBs] - [On Order LBs] - [Ordered Reserved LBs])
			MEASURE Fact_PlannedPurchaseTransferProd_Orders[Requirement Quantity] = SUM(Fact_PlannedPurchaseTransferProd_Orders[RequirementQuantity])
			---- MODEL MEASURES END ----
			```

