		changedProperty = Name

	measure 'Historical RM Demand LBs' =
			
			VAR RawMaterialKeys =
			    VALUES ( 'Dim_Product'[ProductKey] )
			
			VAR ValidFormulaSites =
			    FILTER (
			        ALL ( 'Fact_FinishedGoodsRawMaterials'[RmSiteId] ),
			        'Fact_FinishedGoodsRawMaterials'[RmSiteId] <> "90"
			    )
			
			VAR BomRowsForSelectedRawMaterials =
			    SELECTCOLUMNS (
			        SUMMARIZE (
			            CALCULATETABLE (
			                'Fact_FinishedGoodsRawMaterials',
			                REMOVEFILTERS ( 'Fact_FinishedGoodsRawMaterials' ),
			                REMOVEFILTERS ( 'DIM_Site' ),
			                TREATAS (
			                    RawMaterialKeys,
			                    'Fact_FinishedGoodsRawMaterials'[RawMaterialProductKey]
			                ),
			                ValidFormulaSites
			            ),
			            'Fact_FinishedGoodsRawMaterials'[RawMaterialProductKey],
			            'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey],
			            "RMPerLbFG",
			                SUM ( 'Fact_FinishedGoodsRawMaterials'[RawMaterialAmtPerLbFG] )
			        ),
			        "RawMaterialKey", 'Fact_FinishedGoodsRawMaterials'[RawMaterialProductKey],
			        "FinishedGoodKey", 'Fact_FinishedGoodsRawMaterials'[FinishedGoodProductKey],
			        "RMPerLbFG", [RMPerLbFG]
			    )
			
			VAR Result =
			    SUMX (
			        BomRowsForSelectedRawMaterials,
			        VAR ThisFinishedGoodKey = [FinishedGoodKey]
			        VAR ThisRMPerLbFG = [RMPerLbFG]
			
			        VAR FinishedGoodSoldLbs =
			            CALCULATE (
			                [Quantity LBs],
			                REMOVEFILTERS ( 'Dim_Product' ),
			                REMOVEFILTERS ( 'Dim_Date' ),
			                TREATAS (
			                    { ThisFinishedGoodKey },
			                    'Dim_Product'[ProductKey]
			                )
			            )
			
			        RETURN
			            FinishedGoodSoldLbs * ThisRMPerLbFG
			    )
			
			RETURN
			    COALESCE ( Result, 0 )
		lineageTag: 6cf4f64a-9a9d-4f1e-8994-bd2a5d3d1bb2

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Historical Demand Gap LBs' =
			
			[Physical Inventory LBs] - [Historical RM Demand LBs]
		lineageTag: a483abaf-4c31-436d-ba08-76f435ee456a

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Historical Demand Coverage Ratio' =
			
			DIVIDE ( [Physical Inventory LBs], [Historical RM Demand LBs] )
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: 732083f2-a1f7-4fc8-96a6-9c8f3d9b51e6

		changedProperty = Name

		changedProperty = FormatString

	measure 'Selected Sales Horizon Days' =
			
			VAR DateWindow =
			    CALCULATETABLE (
			        ALLSELECTED ( 'Fact_Sales'[OrderDate] ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Fact_FinishedGoodsRawMaterials' ),
			        REMOVEFILTERS ( 'Dim_Date' )
			    )
			
			VAR MinDate =
			    MINX (
			        DateWindow,
			        INT ( 'Fact_Sales'[OrderDate] )
			    )
			
			VAR MaxDate =
			    MAXX (
			        DateWindow,
			        INT ( 'Fact_Sales'[OrderDate] )
			    )
			
			RETURN
			    IF (
			        NOT ISBLANK ( MinDate )
			            && NOT ISBLANK ( MaxDate ),
			        MaxDate - MinDate + 1
			    )
		formatString: 0
		lineageTag: 58ec56dc-959f-45e5-994d-77c4eac1641f

		changedProperty = Name

	measure 'Avg Daily RM Demand LBs' =
			
			DIVIDE (
			    [Historical RM Demand LBs],
			    [Selected Sales Horizon Days]
			)
		lineageTag: e05489c3-6d4f-45dd-aadf-2dc452a0f879

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Days on Hand' =
			
			DIVIDE (
			    [Physical Inventory LBs],
			    [Avg Daily RM Demand LBs]
			)
		lineageTag: fc4e7f7e-cbe9-4215-be2c-85cc24034c5e

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Days Supply incl. On-Order' =
			
			DIVIDE (
			    [Physical Inventory LBs] + [Ordered Qty LBs],
			    [Avg Daily RM Demand LBs]
			)
		lineageTag: 6dc2eba9-40bc-42bd-a417-9accc7165135

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Notes Title' =
			
			"Inventory as of "
			    & FORMAT ( [Most Recent Snapshot Date], "MM/dd/yy" )
		lineageTag: 044f2814-90e7-4758-af5d-2643e1d649eb

		changedProperty = Name

	measure 'Most Recent Snapshot Date' =
			
			MAX ( 'Fact_Inventory_Snapshot'[Snapshot_Date] )
		formatString: General Date
		lineageTag: 0cb9848a-7814-4101-8ffb-f3a8e345dd32

		changedProperty = Name

	measure 'Selected RM Demand Trend Lbs' =
			
			VAR ShowChart =
			    [RMHT - Show FG Detail] = 1
			
			VAR AxisStartDate =
			    MIN ( 'Dim_Date'[Date] )
			
			VAR AxisEndDate =
			    MAX ( 'Dim_Date'[Date] )
			
			VAR HorizonStartDateTime =
			    CALCULATE (
			        MIN ( 'Fact_Sales'[OrderDate] ),
			        REMOVEFILTERS ( 'Dim_Date' ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Fact_FinishedGoodsRawMaterials' )
			    )
			
			VAR HorizonEndDateTime =
			    CALCULATE (
			        MAX ( 'Fact_Sales'[OrderDate] ),
			        REMOVEFILTERS ( 'Dim_Date' ),
			        REMOVEFILTERS ( 'Dim_Product' ),
			        REMOVEFILTERS ( 'Fact_FinishedGoodsRawMaterials' )
			    )
			
			VAR HorizonStartDate =
			    IF (
			        NOT ISBLANK ( HorizonStartDateTime ),
			        INT ( HorizonStartDateTime )
			    )
			
			VAR HorizonEndDate =
			    IF (
			        NOT ISBLANK ( HorizonEndDateTime ),
			        INT ( HorizonEndDateTime )
			    )
			
			VAR AxisOverlapsSalesHorizon =
			    NOT ISBLANK ( AxisStartDate )
			        && NOT ISBLANK ( AxisEndDate )
			        && NOT ISBLANK ( HorizonStartDate )
			        && NOT ISBLANK ( HorizonEndDate )
			        && AxisEndDate >= HorizonStartDate
			        && AxisStartDate <= HorizonEndDate
			
			RETURN
			    IF (
			        ShowChart
			            && AxisOverlapsSalesHorizon,
			        VAR DemandForAxisPeriod =
			            CALCULATE (
			                [Historical RM Demand LBs],
			                REMOVEFILTERS ( 'Dim_Date' ),
			                KEEPFILTERS (
			                    'Fact_Sales'[OrderDate] >= AxisStartDate
			                ),
			                KEEPFILTERS (
			                    'Fact_Sales'[OrderDate] < AxisEndDate + 1
			                )
			            )
			        RETURN
			            IF (
			                DemandForAxisPeriod <> 0,
			                DemandForAxisPeriod
			            )
			    )
		lineageTag: 413bffbf-31e4-47a6-8921-5cae982e9053

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

