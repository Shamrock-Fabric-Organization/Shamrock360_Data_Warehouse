	measure 'Weekly Average Revenue (Sales Days)' = ```
			
			
			VAR wkStart =
			    SELECTEDVALUE ( Dim_Date[WeekStartDate] )
			RETURN
			IF (
			    ISBLANK ( wkStart ),
			    BLANK (),
			    VAR wkEnd = wkStart + 6
			
			    VAR TodayDate = TODAY ()
			    VAR NowEST =
			        NOW() - TIME ( 5, 0, 0 )   -- adjust to EST (or 4 for EDT)
			
			    VAR AfterCutoffToday =
			        NowEST >= ( TodayDate + TIME ( 19, 0, 0 ) )
			
			    -- Dates in the selected week, excluding future days,
			    -- and excluding "today" until after 7PM
			    VAR WeekDatesEligible =
			        FILTER (
			            DATESBETWEEN ( Dim_Date[Date], wkStart, wkEnd ),
			            Dim_Date[Date] <= TodayDate
			                && ( Dim_Date[Date] < TodayDate || AfterCutoffToday )
			        )
			
			    VAR TrackedSites =
			        FILTER (
			            ALL ( DIM_Warehouse ),
			            CONTAINSSTRING ( DIM_Warehouse[Site_Name], "Kentucky" )
			                || CONTAINSSTRING ( DIM_Warehouse[Site_Name], "New Jersey" )
			                || CONTAINSSTRING ( DIM_Warehouse[Site_Name], "South Carolina" )
			        )
			
			    -- Numerator: all eligible dates in the week (Mon-Sun),
			    -- so weekend catch-up is included in the week's total
			    VAR RevenueIncluded =
			        CALCULATE (
			            [SalesAmount],
			            WeekDatesEligible,
			            KEEPFILTERS ( TrackedSites )
			        )
			
			    -- Denominator: only Mon-Fri dates with any records/orders
			    VAR WeekdayOrderDays =
			        FILTER (
			            WeekDatesEligible,
			            WEEKDAY ( Dim_Date[Date], 2 ) <= 5
			                && CALCULATE ( [Total Orders], KEEPFILTERS ( TrackedSites ) ) > 0
			        )
			
			    VAR SalesDaysIncluded =
			        COUNTROWS ( WeekdayOrderDays )
			
			    RETURN
			        DIVIDE ( RevenueIncluded, SalesDaysIncluded )
			)
			
			```
		lineageTag: 91a57510-efad-4129-8618-3792c5791329

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Monthly Avg Revenue (30-day)' = ```
			
			VAR RevenuePerMonth =
			    CALCULATE (
			        [SalesAmount],
			        ALLEXCEPT ( 'Dim_Date', 'Dim_Date'[MonthStartDate] )
			    )
			RETURN
			DIVIDE ( RevenuePerMonth, 30 )
			
			```
		lineageTag: d1c2c76c-3c56-4c62-85a0-4057ad971809

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Moving Avg (3 Months)' = ```
			
			VAR ThisWeek =
			    MAX ( 'Dim_Date'[WeekStartDate] )
			
			-- first day of the month 3 months before current month
			VAR WindowStart =
			    EOMONTH ( ThisWeek, -3 ) + 1
			
			VAR WeeksInRange =
			    FILTER (
			        ALL ( 'Dim_Date'[WeekStartDate] ),
			        'Dim_Date'[WeekStartDate] >= WindowStart
			            && 'Dim_Date'[WeekStartDate] <= ThisWeek
			    )
			RETURN
			AVERAGEX ( WeeksInRange, [Weekly Average Revenue (Sales Days)] )
			
			```
		lineageTag: 3ec7068d-0292-425e-9eb0-7a2f9c8dbb46

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Moving Avg (4 Weeks)' = ```
			
			VAR CurrentWeek =
			    MAX ( 'Dim_Date'[WeekStartDate] )
			VAR Last4Weeks =
			    TOPN (
			        4,
			        FILTER (
			            ALL ( 'Dim_Date'[WeekStartDate] ),
			            'Dim_Date'[WeekStartDate] <= CurrentWeek
			        ),
			        'Dim_Date'[WeekStartDate],
			        DESC
			    )
			RETURN
			AVERAGEX ( Last4Weeks, [Weekly Average Revenue (Sales Days)] )
			
			```
		lineageTag: 5ebe5c13-87b9-4726-b75b-4e98b27bbc69

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

