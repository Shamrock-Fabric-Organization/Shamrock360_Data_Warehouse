	measure '360 - Revenue rolling average' = ```
			
			
			VAR LastEOM =
			    EOMONTH ( MAX ( 'Dim_Date'[Date] ), 0 )          -- last day of current context month
			
			VAR StartDate =
			    EOMONTH ( LastEOM, -12 ) + 1                     -- first day 12 months earlier
			
			-- 12‑month window ending at LastEOM, ignoring current row context
			VAR Period =
			    CALCULATETABLE (
			        DATESBETWEEN ( 'Dim_Date'[Date], StartDate, LastEOM ),
			        ALL ( 'Dim_Date' )
			    )
			
			VAR Total12M =
			    CALCULATE (
			        SUM ( 'Fact_Sales'[Amount] ),
			        USERELATIONSHIP (
			            'Fact_Sales'[InvoiceDateKey],
			            'Dim_Date'[DateKey]
			        ),
			        Period
			    )
			
			VAR MonthsInWindow =
			    CALCULATE (
			        DISTINCTCOUNT ( 'Dim_Date'[MonthStartDate] ),
			        Period
			    )
			
			RETURN
			DIVIDE ( Total12M, MonthsInWindow )
			
			```
		lineageTag: bc676fe9-2484-4804-a365-c9822bdeb373

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '360 - Invoiced Amount' =
			
			CALCULATE (
