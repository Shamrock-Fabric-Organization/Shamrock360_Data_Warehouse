	measure '360 - Volume rolling average' = ```
			
			
			VAR LastEOM =
			    EOMONTH ( MAX ( 'Dim_Date'[Date] ), 0 )          -- last day of current context month
			
			VAR StartDate =
			    EOMONTH ( LastEOM, -12 ) + 1                     -- first day 12 months earlier
			
			-- 12‑month window ending at LastEOM, ignoring current row context
			VAR Period =
			    CALCULATETABLE (
			        DATESBETWEEN ( 'Dim_Date'[Date], StartDate, LastEOM ),
			        ALL ( 'Dim_Date' )
			    )
			
			VAR Total12M =
			    CALCULATE (
			        SUM ( 'Fact_Sales'[Quantity_LBs] ),
			        USERELATIONSHIP (
			            'Fact_Sales'[InvoiceDateKey],
			            'Dim_Date'[DateKey]
			        ),
			        Period
			    )
			
			VAR MonthsInWindow =
			    CALCULATE (
			        DISTINCTCOUNT ( 'Dim_Date'[MonthStartDate] ),
			        Period
			    )
			
			RETURN
			DIVIDE ( Total12M, MonthsInWindow )
			
			```
		lineageTag: 91499962-954d-44bb-bda4-453d5dd7457b

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

