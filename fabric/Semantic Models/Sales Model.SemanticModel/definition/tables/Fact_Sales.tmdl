	measure '360 - Revenue running total in FISCAL Day' =
			
			VAR AsOfDate =
			    TODAY()   -- use the same as-of date logic as your cards if different
			VAR CurrFY =
			    CALCULATE (
			        MAX ( Dim_Date[FiscalYear] ),
			        FILTER ( ALL ( Dim_Date ), Dim_Date[Date] = AsOfDate )
			    )
			VAR CurrPeriod =
			    CALCULATE (
			        MAX ( Dim_Date[FiscalPeriodNum] ),
			        FILTER ( ALL ( Dim_Date ), Dim_Date[Date] = AsOfDate )
			    )
			VAR CurrDay =
			    CALCULATE (
			        MAX ( Dim_Date[FiscalDayNum] ),
			        FILTER ( ALL ( Dim_Date ), Dim_Date[Date] = AsOfDate )
			    )
			VAR AxisFY =
			    SELECTEDVALUE ( Dim_Date[FiscalYear] )
			VAR AxisPeriod =
			    MAX ( Dim_Date[FiscalPeriodNum] )
			VAR PeriodEndDay =
			    CALCULATE (
			        MAX ( Dim_Date[FiscalDayNum] ),
			        FILTER (
			            ALL ( Dim_Date ),
			            Dim_Date[FiscalYear] = AxisFY
			                && Dim_Date[FiscalPeriodNum] = AxisPeriod
			        )
			    )
			VAR CutoffDay =
			    SWITCH (
			        TRUE (),
			        AxisFY = CurrFY && AxisPeriod >= CurrPeriod, CurrDay,   -- keep current year flat after current point
			        AxisPeriod = CurrPeriod, CurrDay,                       -- align prior years at current period
			        PeriodEndDay                                            -- full period otherwise
			    )
			RETURN
			CALCULATE (
			    [360 - Invoiced Amount],
			    FILTER (
			        ALL ( Dim_Date ),
			        Dim_Date[FiscalYear] = AxisFY
			            && Dim_Date[FiscalDayNum] <= CutoffDay
			    )
			)
		lineageTag: fc667e2f-4e09-405c-9a8f-afe32774cbdc

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

