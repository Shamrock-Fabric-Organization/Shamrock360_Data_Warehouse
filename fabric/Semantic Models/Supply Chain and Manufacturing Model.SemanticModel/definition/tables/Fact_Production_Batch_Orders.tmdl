table Fact_Production_Batch_Orders
	lineageTag: accea10f-7a52-4c7a-b832-da7ea83c022c
	sourceLineageTag: [dbo].[mtbl_EDW_Fact_Production_Batch_Orders]

	measure 'Schedule Start' = ```
			
			VAR dk = VALUES ( 'Fact_Production_Batch_Orders'[schedstartdatekey] )
			RETURN
			CALCULATE (
			    SELECTEDVALUE ( 'Dim_Date'[Date] ),
			    -- neutralize any existing Dim_Date filter coming from the active relationship
			    REMOVEFILTERS ( 'Dim_Date' ),
			    -- apply the requested-ship keys as a filter on the date dimension
			    TREATAS ( dk, 'Dim_Date'[DateKey] )
			)
			
			```
		formatString: General Date
		lineageTag: cf7a4df6-6cb9-450b-bfd3-72f8b655be5a

		changedProperty = Name

	measure 'Schedule End' = ```
			
			VAR dk = VALUES ( 'Fact_Production_Batch_Orders'[schedenddatekey] )
			RETURN
			CALCULATE (
			    SELECTEDVALUE ( 'Dim_Date'[Date] ),
			    -- neutralize any existing Dim_Date filter coming from the active relationship
			    REMOVEFILTERS ( 'Dim_Date' ),
			    -- apply the requested-ship keys as a filter on the date dimension
			    TREATAS ( dk, 'Dim_Date'[DateKey] )
			)
			
			```
		formatString: General Date
		lineageTag: 01498978-c4fb-4462-868b-7ae0d3378960

		changedProperty = Name

	measure 'As Of Date' = TODAY()
		formatString: General Date
		lineageTag: 3a319430-c8f0-4f55-b265-b11f5659fe32

		changedProperty = Name

	measure 'Open Qty Remaining (Scope)' = ```
			
			VAR asOf = [As Of Date]
			VAR pboscope = SELECTEDVALUE ( 'PBO Scope'[Scope], "All Open" )
			RETURN
			SWITCH (
			    pboscope,
			    "All Open",
			        CALCULATE (
			            SUM ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0
			        ),
			    "Due ≤ 30 Days",
			        CALCULATE (
			            SUM ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] <= asOf + 30
			        ),
			    "Overdue Only",
			        CALCULATE (
			            SUM ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] < asOf
			        )
			)
			
			```
		lineageTag: 7f4e821b-7f3b-4b81-a0ec-4fbc5f2d0b76

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Open PBO Count (Scope)' = ```
			
			VAR asOf = [As Of Date]
			VAR pboscope = SELECTEDVALUE ( 'PBO Scope'[Scope], "All Open" )
			RETURN
			SWITCH (
			    pboscope,
			    "All Open",
			        CALCULATE (
			            DISTINCTCOUNT ( Fact_Production_Batch_Orders[ProductionBatchOrder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0
			        ),
			    "Due ≤ 30 Days",
			        CALCULATE (
			            DISTINCTCOUNT ( Fact_Production_Batch_Orders[ProductionBatchOrder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] <= asOf + 30
			        ),
			    "Overdue Only",
			        CALCULATE (
			            DISTINCTCOUNT ( Fact_Production_Batch_Orders[ProductionBatchOrder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] < asOf
			        )
			)
			
			```
		formatString: 0
		lineageTag: 897691ed-1f0c-4266-8cb5-3ccb8b631747

		changedProperty = Name

	measure 'Late Open Qty Remaining (Scope)' = ```
			
			VAR asOf = [As Of Date]
			VAR pboscope = SELECTEDVALUE ( 'PBO Scope'[Scope], "All Open" )
			RETURN
			SWITCH (
			    pboscope,
			    "All Open",
			        CALCULATE (
			            SUM ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] < asOf
			        ),
			    "Due ≤ 30 Days",
			        CALCULATE (
			            SUM ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] <= asOf + 30,
			            Dim_Date[Date] < asOf
			        ),
			    "Overdue Only",
			        -- same as open under this scope
			        [Open Qty Remaining (Scope)]
			)
			
			```
		lineageTag: 1121921a-7829-433c-9272-2ecdad7dbae5

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Late Open PBO Count (Scope)' = ```
			
			VAR asOf = [As Of Date]
			VAR pboscope = SELECTEDVALUE ( 'PBO Scope'[Scope], "All Open" )
			RETURN
			SWITCH (
			    pboscope,
			    "All Open",
			        CALCULATE (
			            DISTINCTCOUNT ( Fact_Production_Batch_Orders[ProductionBatchOrder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Dim_Date[Date] ),
			            Dim_Date[Date] < asOf
			        ),
			    "Due ≤ 30 Days",
			        CALCULATE (
			            DISTINCTCOUNT ( Fact_Production_Batch_Orders[ProductionBatchOrder] ),
			            Fact_Production_Batch_Orders[ReportRemainder] > 0,
			            NOT ISBLANK ( Fact_Production_Batch_Orders[ReportRemainder] ),
			            Dim_Date[Date] <= asOf + 30,
			            Dim_Date[Date] < asOf
			        ),
			    "Overdue Only",
			        [Open PBO Count (Scope)]
			)
			
			```
		formatString: 0
		lineageTag: f7d26f03-724b-486b-ba2d-078b1e3ac7c8

		changedProperty = Name

	measure '% Late (by Qty)' =
			
			COALESCE (
			    DIVIDE (
			        [Late Open Qty Remaining (Scope)],
			        [Open Qty Remaining (Scope)]
			    ),
			    0
			)
		lineageTag: c224a98f-39d9-49b6-a046-7184bc7311e0

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'PBO - Is Open & Late (Bool)' = ```
			
			VAR QtyRemaining =
			    SUM ( Fact_Production_Batch_Orders[ReportRemainder] )
			VAR DueDate =
			    MIN ( Dim_Date[Date] )
			RETURN
			    QtyRemaining > 0
			        && NOT ISBLANK ( DueDate )
			        && DueDate < TODAY ()
			
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a4e0afb6-fee5-4964-9631-0bdbd68dff4a

		changedProperty = Name

	measure 'PBO - Is Open & Late (Flag)' = ```
			
			IF ( [PBO - Is Open & Late (Bool)], 1, 0 )
			
			```
		formatString: 0
		lineageTag: 94f4c906-034c-4418-9bac-5f92a0c9d3f8

		changedProperty = Name

