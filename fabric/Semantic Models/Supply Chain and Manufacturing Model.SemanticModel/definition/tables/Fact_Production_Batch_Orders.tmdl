		changedProperty = Name

	measure 'Global Axis Max ReportRemainder + 10%' =
			
			VAR MaxAcrossWarehouses =
			    MAXX(
			        ALLSELECTED( 'Dim_Warehouse'[Warehouse_ID] ),
			        CALCULATE( [ReportRemainder (Sum)] )
			    )
			RETURN
			    MaxAcrossWarehouses * 1.10
		lineageTag: a548b59a-6cac-470c-8b8d-25afaacd70e0

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'ReportRemainder (Sum)' =
			
			SUM ( 'Fact_Production_Batch_Orders'[ReportRemainder] )
		lineageTag: 127b7980-64dc-44b2-8cf9-cb3b5f71d845

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Global Max ReportRemainder + 10% - RouteType' =
			
			VAR MaxAcrossWarehouses =
			    MAXX(
			        ALLSELECTED( 'Dim_Route'[RouteType] ),
			        CALCULATE( [ReportRemainder (Sum)] )
			    )
			RETURN
			    MaxAcrossWarehouses * 1.10
		lineageTag: 3ac80245-1a5b-4bb5-8474-d09bc72c4afd

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

